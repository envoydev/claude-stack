# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Node
node_modules/
# the repo's own lock stays local (single dev dep); the examples' locks stay TRACKED (they pin the worked reference projects)
/package-lock.json

# Windows
Thumbs.db

# claude
.claude/
REPORT.md

# Stack-generated, machine-local artifacts (never commit)
.serena/
.mcp.json

# local research input (contains private project names) - never commit
best-practice/

# examples: worked reference projects - track clean source, exclude build caches,
# stack state, and grader-only harness artifacts. (node_modules/.claude/.serena/.mcp.json/
# .vscode/REPORT.md/.DS_Store are already ignored globally above.)
examples/**/.angular/
examples/**/.playwright/
examples/**/dist/
examples/**/bin/
examples/**/obj/
examples/**/*.db
examples/**/*.db-wal
examples/**/*.db-shm
examples/ANSWER-KEY.md
examples/*ANSWER-KEY*.md
examples/*-test-prompt.md
examples/RUN-*PHASES*.md
examples/**/RETEST-REPORT.md
examples/**/VERIFY-REPORT.md

# docs: the committed architecture map (docs/architecture/) + repo docs stay tracked; only the
# superpowers / brainstorming scratch specs are local-only.
**/docs/superpowers/
