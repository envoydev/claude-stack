{
  "always": {
    "agents": [
      "ci-failure-diagnoser",
      "issue-diagnoser",
      "integration-reviewer",
      "evidence-gatherer",
      "code-analyzer",
      "related-project-analyzer"
    ],
    "rules": [
      "baseline-docs-root",
      "baseline-git",
      "baseline-interaction",
      "baseline-navigation",
      "baseline-quality-gates",
      "baseline-security",
      "markdown-docs"
    ],
    "mcps": [
      "serena",
      "context7",
      "memory",
      "playwright"
    ],
    "hooks": [
      "guard-protected-force-push",
      "guard-catastrophic-rm",
      "guard-read-whole-file"
    ],
    "skills": [
      "project-agent-capabilities",
      "project-architecture-analyzer",
      "project-architecture-quality-loop",
      "project-code-style-analyzer",
      "project-implementer",
      "project-quality-loop",
      "project-related-context",
      "project-solve-cross-task",
      "project-solve-task",
      "project-verify-code",
      "project-verify-plan",
      "project-version-upgrade"
    ]
  },
  "general": {
    "skills": [
      "csharp-design-patterns",
      "dotnet-migrate",
      "dotnet-hosted-services",
      "dotnet-data-access",
      "frontend",
      "project-stack-usage-analyzer"
    ]
  },
  "stacks": {
    "aspnet": {
      "agents": [
        "aspnet-solution-designer",
        "aspnet-implementer",
        "aspnet-verifier",
        "dotnet-build-error-resolver",
        "dotnet-test-failure-resolver"
      ],
      "rules": [
        "csharp-conventions",
        "dotnet-repair-agents"
      ],
      "plugins": [
        "csharp-lsp"
      ]
    },
    "angular": {
      "agents": [
        "angular-solution-designer",
        "angular-implementer",
        "angular-verifier",
        "ng-build-error-resolver",
        "angular-test-resolver"
      ],
      "rules": [
        "typescript-conventions",
        "angular-conventions",
        "angular-styling-conventions",
        "angular-repair-agents"
      ],
      "plugins": [
        "typescript-lsp"
      ],
      "mcps": [
        "angular-cli",
        "chrome-devtools"
      ]
    },
    "wpf": {
      "agents": [
        "wpf-solution-designer",
        "wpf-implementer",
        "wpf-verifier",
        "dotnet-build-error-resolver",
        "dotnet-test-failure-resolver"
      ],
      "rules": [
        "csharp-conventions",
        "wpf-conventions",
        "dotnet-repair-agents"
      ],
      "plugins": [
        "csharp-lsp"
      ]
    },
    "console": {
      "agents": [
        "console-solution-designer",
        "console-implementer",
        "console-verifier",
